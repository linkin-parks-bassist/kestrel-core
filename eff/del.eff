v1.0

.INFO

name: "Delay"
cname: "delay"

.PARAMETERS

delay_gain: (name: "Delay Gain", default: 0.5, min: 0, max: 1.0, group: 1)

.SETTINGS

delay_ms: (name: "Delay", type: "int", default: 4, min: 0, max: 370, page: "main", group: 2, units: " ms")

.RESOURCES

delay1: (type: "delay", delay: delay_ms)

.CODE

delay_read $delay1 c1
madd c1 [delay_gain] c0 c0
delay_write c0 $delay1
